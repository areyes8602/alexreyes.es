        { "letra": "p", "puntos": 0, "tarea": "$f_{16}(x) = \\sqrt{\\,-\\dfrac{x-4}{3x-9}\\,}$" },
        { "letra": "q", "puntos": 0, "tarea": "$f_{17}(x) = \\ln(x^{2}+4)$" },
        { "letra": "r", "puntos": 0, "tarea": "$f_{18}(x) = \\sqrt{x^{2}-4}$" },
        { "letra": "s", "puntos": 0, "tarea": "$f_{19}(x) = \\begin{cases} \\dfrac{1}{x-4} & x > 5 \\\\ \\ln(-3x+20) & x < 5 \\end{cases}$" },
