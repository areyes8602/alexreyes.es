        { "letra": "e", "puntos": 0, "tarea": "$f_{5}(x) = \\sqrt[5]{2x+1}$" },
        { "letra": "f", "puntos": 0, "tarea": "$f_{6}(x) = \\dfrac{(x-1)(x-2)}{x+1}$" },
        { "letra": "g", "puntos": 0, "tarea": "$f_{7}(x) = \\dfrac{(x-1)(x-2)}{x-1}$" },
        { "letra": "h", "puntos": 0, "tarea": "$f_{8}(x) = \\dfrac{\\sqrt{x+3}}{x+1}$" },
        { "letra": "i", "puntos": 0, "tarea": "$f_{9}(x) = \\dfrac{x+4}{\\sqrt{2x+6}}$" },
        { "letra": "j", "puntos": 0, "tarea": "$f_{10}(x) = \\dfrac{2}{x^{2}+1}$" },
        { "letra": "k", "puntos": 0, "tarea": "$f_{11}(x) = \\dfrac{2}{x^{2}-1}$" },
        { "letra": "l", "puntos": 0, "tarea": "$f_{12}(x) = \\dfrac{\\sqrt{x+2}}{\\sqrt{x-3}}$" },
        { "letra": "m", "puntos": 0, "tarea": "$f_{13}(x) = \\dfrac{\\sqrt{x^{2}-16}}{5x+1}$" },
        { "letra": "n", "puntos": 0, "tarea": "$f_{14}(x) = \\sqrt{\\dfrac{2x+4}{x-3}}$" },
