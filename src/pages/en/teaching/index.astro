---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Teaching" lang="en">
  <div class="container" style="padding-top: 4rem; padding-bottom: 6rem;">

    <div class="page-header">
      <span class="section-title">Teaching</span>
      <h1>Courses and materials</h1>
      <p class="page-desc">
        Resources organised by course. Classroom materials (exams, term exercises, answer keys) are restricted to enrolled students. Open resources are available to any visitor.
      </p>
    </div>

    <div class="courses-grid">

      <div class="course-card">
        <div class="course-card__header">
          <div class="course-card__level">IB · Year 13</div>
          <span class="tag tag--orange">classroom access</span>
        </div>
        <h2 class="course-card__title">IB Mathematics<br>Analysis & Approaches HL</h2>
        <p class="course-card__desc">Calculus, algebra, geometry, statistics and probability at the highest IB level. Focus on proof and mathematical rigour.</p>
        <ul class="course-card__topics">
          <li>Algebra and functions</li>
          <li>Differential and integral calculus</li>
          <li>Geometry and trigonometry</li>
          <li>Statistics and probability</li>
          <li>Complex numbers</li>
        </ul>
        <a href="/docencia/ib-aa-hl" class="btn btn--secondary course-card__btn">View materials &rarr;</a>
      </div>

      <div class="course-card">
        <div class="course-card__header">
          <div class="course-card__level">IB · Year 13</div>
          <span class="tag tag--orange">classroom access</span>
        </div>
        <h2 class="course-card__title">IB Mathematics<br>Applications & Interpretation HL</h2>
        <p class="course-card__desc">Applied mathematics with emphasis on modelling and technology (Casio CG-50). Includes ODEs, numerical methods and advanced statistics.</p>
        <ul class="course-card__topics">
          <li>Algebra and modelling</li>
          <li>Differential equations (Euler)</li>
          <li>Inferential statistics</li>
          <li>Projectile motion</li>
          <li>Casio CG-50 — advanced techniques</li>
        </ul>
        <a href="/docencia/ib-ai-hl" class="btn btn--secondary course-card__btn">View materials &rarr;</a>
      </div>

      <div class="course-card">
        <div class="course-card__header">
          <div class="course-card__level">ESO · Year 7</div>
          <span class="tag tag--orange">classroom access</span>
        </div>
        <h2 class="course-card__title">Mathematics<br>Year 7 (1r ESO)</h2>
        <p class="course-card__desc">Numbers, geometry, introductory algebra and basic statistics. Gamified activities and resources for home revision.</p>
        <ul class="course-card__topics">
          <li>Natural and integer numbers</li>
          <li>Fractions and decimals</li>
          <li>Proportionality</li>
          <li>Plane geometry</li>
          <li>Basic descriptive statistics</li>
        </ul>
        <a href="/docencia/1eso" class="btn btn--secondary course-card__btn">View materials &rarr;</a>
      </div>

      <div class="course-card course-card--open">
        <div class="course-card__header">
          <div class="course-card__level">All levels</div>
          <span class="tag tag--green">public</span>
        </div>
        <h2 class="course-card__title">Open resources</h2>
        <p class="course-card__desc">Freely shared materials: revision activities, visualisations, teaching notes and resources for any maths student.</p>
        <ul class="course-card__topics">
          <li>Gamification activities</li>
          <li>Interactive visualisations</li>
          <li>Mathematics teaching notes</li>
          <li>University entrance exam prep</li>
        </ul>
        <a href="/docencia/recursos" class="btn btn--secondary course-card__btn">View resources &rarr;</a>
      </div>

    </div>

    <div class="teaching-note">
      <div class="teaching-note__icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <p>Classroom materials are protected. If you are a student and cannot access them, contact me directly in class or by email to receive the access link.</p>
    </div>

  </div>
</BaseLayout>

<style>
.page-header {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--border);
  max-width: 600px;
}
.page-header h1 { margin: 0.5rem 0 1rem; }
.page-desc {
  font-size: 1.05rem;
  color: var(--text-soft);
  line-height: 1.65;
}

.courses-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}

.course-card {
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.course-card:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
}
.course-card--open {
  border-style: dashed;
}

.course-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.course-card__level {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-faint);
}
.course-card__title {
  font-size: 1.25rem;
  line-height: 1.25;
  margin-top: 0.3rem;
}
.course-card__desc {
  font-size: 0.92rem;
  color: var(--text-soft);
  line-height: 1.6;
}
.course-card__topics {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  flex: 1;
}
.course-card__topics li {
  font-size: 0.85rem;
  color: var(--text-faint);
  padding-left: 1rem;
  position: relative;
}
.course-card__topics li::before {
  content: "—";
  position: absolute;
  left: 0;
  color: var(--border-strong);
}
.course-card__btn {
  font-size: 0.85rem;
  margin-top: 0.5rem;
  align-self: flex-start;
}

.teaching-note {
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 1.2rem 1.5rem;
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}
.teaching-note__icon {
  color: var(--text-faint);
  flex-shrink: 0;
  margin-top: 2px;
}
.teaching-note p {
  font-size: 0.88rem;
  color: var(--text-faint);
  line-height: 1.6;
}

@media (max-width: 768px) {
  .courses-grid { grid-template-columns: 1fr; }
}
</style>
