---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Teaching" lang="en">
  <div class="container" style="padding-top: 4rem; padding-bottom: 6rem;">

    <div class="page-header">
      <span class="section-title">Teaching</span>
      <h1>Courses and materials</h1>
      <p class="page-desc">
        Material organised by course. Each page includes a permanent layer (syllabus, notes, exercises) and an annual layer updated each year. Classroom access requires authorisation.
      </p>
    </div>

    <div class="season-label">
      <span class="section-title">Year 2025&ndash;26 &mdash; active</span>
    </div>

    <div class="courses-grid">

      <a href="/docencia/ib-ai/" class="course-card">
        <div class="course-card__header">
          <div class="course-card__level">IB Programme</div>
          <div style="display:flex;gap:0.4rem">
            <span class="tag tag--blue">HL</span>
            <span class="tag tag--blue">SL</span>
          </div>
        </div>
        <h2 class="course-card__title">Mathematics: Applications &amp; Interpretation</h2>
        <p class="course-card__desc">HL and SL. Two active cohorts: 2024&ndash;2026 and 2025&ndash;2027. Oxford AI HL/SL, 16 chapters.</p>
        <ul class="course-card__topics">
          <li>Algebra and modelling</li>
          <li>Statistics and inference</li>
          <li>Numerical calculus (Euler)</li>
          <li>Casio CG-50 — advanced techniques</li>
        </ul>
        <div class="course-card__footer">
          <span class="tag tag--orange">classroom access</span>
          <span class="course-card__link">View materials &rarr;</span>
        </div>
      </a>

      <a href="/docencia/ccss-1btl/" class="course-card">
        <div class="course-card__header">
          <div class="course-card__level">Year 12 (1º Bachillerato)</div>
          <span class="tag tag--gray">BTL</span>
        </div>
        <h2 class="course-card__title">Applied Mathematics for Social Sciences I</h2>
        <p class="course-card__desc">Algebra, functions, statistics and probability for social sciences. University entrance exam preparation.</p>
        <ul class="course-card__topics">
          <li>Matrix algebra</li>
          <li>Functions and graphs</li>
          <li>Statistics and probability</li>
          <li>University entrance prep</li>
        </ul>
        <div class="course-card__footer">
          <span class="tag tag--orange">classroom access</span>
          <span class="course-card__link">View materials &rarr;</span>
        </div>
      </a>

      <a href="/docencia/2eso/" class="course-card">
        <div class="course-card__header">
          <div class="course-card__level">Year 8 (2n ESO) &middot; Groups A &amp; E</div>
          <span class="tag tag--gray">ESO</span>
        </div>
        <h2 class="course-card__title">Mathematics Year 8 (2n d'ESO)</h2>
        <p class="course-card__desc">Numbers, algebra, geometry and statistics. Two groups with shared materials and individual tracking.</p>
        <ul class="course-card__topics">
          <li>Numbers and operations</li>
          <li>Algebra and equations</li>
          <li>Plane and spatial geometry</li>
          <li>Descriptive statistics</li>
        </ul>
        <div class="course-card__footer">
          <span class="tag tag--orange">classroom access</span>
          <span class="course-card__link">View materials &rarr;</span>
        </div>
      </a>

      <a href="/docencia/cangur/" class="course-card course-card--open">
        <div class="course-card__header">
          <div class="course-card__level">Maths competitions</div>
          <span class="tag tag--gray">Competition</span>
        </div>
        <h2 class="course-card__title">Copa Cangur &amp; Prova Cangur</h2>
        <p class="course-card__desc">Preparation resources for mathematics competitions. Problems by level and problem-solving strategies.</p>
        <ul class="course-card__topics">
          <li>Problems by level</li>
          <li>Problem-solving strategies</li>
          <li>International competition</li>
          <li>All ESO and BTL levels</li>
        </ul>
        <div class="course-card__footer">
          <span class="tag tag--green">public</span>
          <span class="course-card__link">View resources &rarr;</span>
        </div>
      </a>

    </div>

    <div class="archive-section">
      <div class="section-header">
        <span class="section-title">Archive &mdash; previous courses</span>
      </div>
      <p class="archive-desc">Permanent materials from courses taught in previous years. Content is available even if not updated annually.</p>
      <div class="archive-grid">
        <div class="archive-card">
          <div class="archive-card__level">ESO (Years 7–10)</div>
          <div class="archive-list">
            <a href="#">Mathematics Year 7 (1r ESO)</a>
            <a href="#">Mathematics Year 9 (3r ESO)</a>
            <a href="#">Mathematics Year 10 (4t ESO)</a>
          </div>
        </div>
        <div class="archive-card">
          <div class="archive-card__level">Year 13 &mdash; Social Sciences</div>
          <div class="archive-list">
            <a href="#">Applied Maths for SS 2º BTL</a>
          </div>
        </div>
        <div class="archive-card">
          <div class="archive-card__level">Year 12–13 &mdash; Sciences</div>
          <div class="archive-list">
            <a href="#">Science Mathematics Year 12</a>
            <a href="#">Science Mathematics Year 13</a>
          </div>
        </div>
      </div>
    </div>

    <div class="teaching-note">
      <div class="teaching-note__icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <p>Classroom materials are protected. If you are a student and cannot access them, contact me directly in class or by email to receive the access link.</p>
    </div>

  </div>
</BaseLayout>

<style>
.page-header {
  margin-bottom: 2rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--border);
  max-width: 600px;
}
.page-header h1 { margin: 0.5rem 0 1rem; }
.page-desc { font-size: 1.05rem; color: var(--text-soft); line-height: 1.65; }

.season-label { margin-bottom: 1.25rem; }

.courses-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-bottom: 3rem;
}

.course-card {
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  transition: border-color 0.2s, box-shadow 0.2s;
  text-decoration: none;
  color: inherit;
}
.course-card:hover { border-color: var(--border-strong); box-shadow: var(--shadow-md); opacity: 1; }
.course-card--open { border-style: dashed; }

.course-card__header { display: flex; justify-content: space-between; align-items: center; }
.course-card__level {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-faint);
}
.course-card__title { font-size: 1.2rem; line-height: 1.25; margin-top: 0.3rem; color: var(--text); }
.course-card__desc { font-size: 0.92rem; color: var(--text-soft); line-height: 1.6; }
.course-card__topics { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; flex: 1; }
.course-card__topics li {
  font-size: 0.85rem;
  color: var(--text-faint);
  padding-left: 1rem;
  position: relative;
}
.course-card__topics li::before { content: "—"; position: absolute; left: 0; color: var(--border-strong); }
.course-card__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 0.5rem;
  padding-top: 0.75rem;
  border-top: 1px solid var(--border);
}
.course-card__link { font-size: 0.82rem; color: var(--text-faint); font-weight: 500; }
.course-card:hover .course-card__link { color: var(--text); }

.tag--blue { color: #2563eb; background: rgba(37,99,235,0.1); }
.tag--gray { color: var(--text-faint); background: var(--tag-bg); }

.archive-section { margin-bottom: 3rem; }
.archive-desc { font-size: 0.92rem; color: var(--text-soft); margin-bottom: 1.5rem; max-width: 600px; line-height: 1.6; }
.archive-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.archive-card { background: var(--bg-subtle); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1.2rem; }
.archive-card__level { font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-faint); margin-bottom: 0.75rem; }
.archive-list { display: flex; flex-direction: column; gap: 0.35rem; }
.archive-list a { font-size: 0.85rem; color: var(--text-soft); }
.archive-list a:hover { color: var(--text); opacity: 1; }

.teaching-note {
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 1.2rem 1.5rem;
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}
.teaching-note__icon { color: var(--text-faint); flex-shrink: 0; margin-top: 2px; }
.teaching-note p { font-size: 0.88rem; color: var(--text-faint); line-height: 1.6; }

@media (max-width: 768px) {
  .courses-grid { grid-template-columns: 1fr; }
  .archive-grid { grid-template-columns: 1fr; }
}
</style>
