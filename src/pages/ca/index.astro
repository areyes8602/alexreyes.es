---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Inici" lang="ca">
  <div class="container" style="padding-top: 5rem; padding-bottom: 6rem;">
    <span class="pill"><span class="dot"></span>Professor · Investigador</span>
    <h1 style="margin: 1.5rem 0 1.5rem; font-size: clamp(2.2rem, 5vw, 3.4rem); letter-spacing: -0.03em; line-height: 1.08;">
      Matemàtiques que ensenyo, aprenc i investigo.
    </h1>
    <p style="font-size: 1.08rem; color: var(--text-soft); max-width: 38rem; line-height: 1.65; margin-bottom: 2rem;">
      Professor de matemàtiques a Barcelona i investigador independent sobre la conjectura de Collatz. Aquest és el meu espai de treball: materials docents, notes de recerca i visualitzacions interactives.
    </p>
    <div style="display: flex; gap: 0.8rem; flex-wrap: wrap;">
      <a href="/ca/investigacio" class="btn btn--primary">Recerca →</a>
      <a href="/ca/docencia" class="btn btn--secondary">Docència</a>
    </div>
    <p style="margin-top: 3rem; font-size: 0.88rem; color: var(--text-faint);">
      → <a href="/">Versión en castellano</a> · <a href="/en">English version</a>
    </p>
  </div>
</BaseLayout>
