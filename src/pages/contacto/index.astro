---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto" lang="es">
  <div class="container--narrow" style="padding-top: 4rem; padding-bottom: 6rem;">

    <div class="page-header">
      <span class="section-title">Contacto</span>
      <h1>Escríbeme</h1>
      <p class="page-desc">Si eres alumno, colega, investigador interesado en el trabajo sobre Collatz, o simplemente quieres ponerte en contacto, aquí tienes la forma de hacerlo.</p>
    </div>

    <div class="contact-grid">
      <div class="contact-card">
        <div class="contact-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div>
          <div class="contact-card__label">Email profesional</div>
          <div class="contact-card__value">a.reyes [at] maristes.cat</div>
          <p class="contact-card__note">Para alumnos, familias y asuntos del centro.</p>
        </div>
      </div>

      <div class="contact-card">
        <div class="contact-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </div>
        <div>
          <div class="contact-card__label">GitHub</div>
          <div class="contact-card__value">github.com/areyes8602</div>
          <p class="contact-card__note">Código, visualizaciones y materiales abiertos.</p>
        </div>
      </div>

      <div class="contact-card">
        <div class="contact-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <div>
          <div class="contact-card__label">Investigación</div>
          <div class="contact-card__value">Correo disponible bajo petición</div>
          <p class="contact-card__note">Para colaboraciones, comentarios sobre el paper o discusiones matemáticas.</p>
        </div>
      </div>
    </div>

    <div class="contact-note">
      <p>📍 Col·legi Maristes Sants — Les Corts · Barcelona</p>
    </div>

  </div>
</BaseLayout>

<style>
.page-header { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
.page-header h1 { margin: 0.5rem 0 1rem; }
.page-desc { font-size: 1.05rem; color: var(--text-soft); line-height: 1.65; }

.contact-grid { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 3rem; }

.contact-card {
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  display: flex;
  gap: 1.2rem;
  align-items: flex-start;
  transition: border-color 0.2s;
}
.contact-card:hover { border-color: var(--border-strong); }
.contact-card__icon { color: var(--text-faint); flex-shrink: 0; margin-top: 2px; }
.contact-card__label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; color: var(--text-faint); margin-bottom: 0.2rem; }
.contact-card__value { font-weight: 500; font-size: 0.98rem; margin-bottom: 0.3rem; font-family: var(--font-mono); font-size: 0.88rem; }
.contact-card__note { font-size: 0.85rem; color: var(--text-faint); line-height: 1.5; }

.contact-note {
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 1rem 1.5rem;
  font-size: 0.88rem;
  color: var(--text-faint);
}
</style>
