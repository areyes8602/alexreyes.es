---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="CV" lang="es">
  <div class="container--narrow" style="padding-top: 4rem; padding-bottom: 6rem;">

    <div class="page-header">
      <span class="section-title">Currículum</span>
      <h1>Àlex Reyes</h1>
      <p class="page-desc">Manuel-Alejandro Reyes Jiménez · Profesor de matemáticas e investigador independiente.</p>
    </div>

    <section class="cv-section">
      <h2 class="cv-section__title">Experiencia docente</h2>
      <div class="cv-entries">
        <div class="cv-entry">
          <div class="cv-entry__period">2018 — actualidad</div>
          <div class="cv-entry__content">
            <div class="cv-entry__role">Profesor de Matemáticas</div>
            <div class="cv-entry__org">Col·legi Maristes Sants — Les Corts · Barcelona</div>
            <p class="cv-entry__desc">IB Mathematics AI HL, IB Mathematics AA HL, 1r d'ESO y otros niveles. Centro donde también estudié de niño.</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-entry__period">2010 — 2018</div>
          <div class="cv-entry__content">
            <div class="cv-entry__role">Profesor de Matemáticas</div>
            <div class="cv-entry__org">Escola Meritxell · Mataró</div>
            <p class="cv-entry__desc">Secundaria y bachillerato. Inicio de la trayectoria docente.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="cv-section">
      <h2 class="cv-section__title">Formación académica</h2>
      <div class="cv-entries">
        <div class="cv-entry">
          <div class="cv-entry__period">Máster</div>
          <div class="cv-entry__content">
            <div class="cv-entry__role">Máster en Formación del Profesorado</div>
            <div class="cv-entry__org">UPC Catalunya</div>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-entry__period">Máster</div>
          <div class="cv-entry__content">
            <div class="cv-entry__role">Máster en Matemática Aplicada</div>
            <div class="cv-entry__org">UPC Catalunya</div>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-entry__period">Grado</div>
          <div class="cv-entry__content">
            <div class="cv-entry__role">Licenciatura en Matemáticas</div>
            <div class="cv-entry__org">UPC Catalunya</div>
          </div>
        </div>
      </div>
    </section>

    <section class="cv-section">
      <h2 class="cv-section__title">Investigación</h2>
      <div class="cv-entries">
        <div class="cv-entry">
          <div class="cv-entry__period">2024 —</div>
          <div class="cv-entry__content">
            <div class="cv-entry__role">Dinámica modular fractal y la conjetura de Collatz</div>
            <div class="cv-entry__org">Investigación independiente · Preprint en preparación</div>
            <p class="cv-entry__desc">Reformulación de la conjetura de Collatz mediante codificaciones binarias $C^m_k$ y fibras congruentes. Destino: arXiv math.NT.</p>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
.page-header { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
.page-header h1 { margin: 0.5rem 0 0.5rem; }
.page-desc { color: var(--text-soft); font-size: 1rem; }

.cv-section { margin-bottom: 3rem; padding-bottom: 3rem; border-bottom: 1px solid var(--border); }
.cv-section:last-child { border-bottom: none; }
.cv-section__title { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-faint); font-weight: 600; margin-bottom: 1.5rem; }

.cv-entries { display: flex; flex-direction: column; gap: 1.5rem; }
.cv-entry { display: grid; grid-template-columns: 130px 1fr; gap: 1.5rem; }
.cv-entry__period { font-size: 0.82rem; color: var(--text-faint); font-family: var(--font-mono); padding-top: 0.15rem; }
.cv-entry__role { font-weight: 600; font-size: 0.98rem; margin-bottom: 0.2rem; }
.cv-entry__org { font-size: 0.88rem; color: var(--text-soft); margin-bottom: 0.5rem; }
.cv-entry__desc { font-size: 0.88rem; color: var(--text-faint); line-height: 1.6; }

@media (max-width: 600px) {
  .cv-entry { grid-template-columns: 1fr; gap: 0.3rem; }
}
</style>
